# --- PostgreSQL (zorunlu: ikisi de) ---
# Neon Console → Connection details:
#   - DATABASE_URL  = "Transaction" veya "Pooled" string (uygulama / serverless)
#   - DIRECT_DATABASE_URL = "Direct" veya host'unda -pooler OLMAYAN string (migrate)
# Tek URL kullanıyorsan (yerel veya sadece direct): ikisine AYNI değeri yapıştır.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require"
#
# Yerel Docker (pooler yok → ikisi aynı):
# DATABASE_URL="postgresql://promptlab:promptlab@localhost:5432/promptlab?schema=public"
# DIRECT_DATABASE_URL="postgresql://promptlab:promptlab@localhost:5432/promptlab?schema=public"

# --- Clerk (giriş / kayıt / OAuth) ---
# https://dashboard.clerk.com → Create application → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# --- Prompt üretimi (birini seçin) ---
# PROMPTLAB_GENERATE_MODE: openai (varsayılan) | groq | mock
# PROMPTLAB_GENERATE_MODE="openai"

OPENAI_API_KEY="sk-..."
# OPENAI_MODEL="gpt-4o-mini"

# Groq (PROMPTLAB_GENERATE_MODE=groq iken zorunlu)
# GROQ_API_KEY="gsk_..."
# GROQ_MODEL="llama-3.3-70b-versatile"

# PROMPTLAB_ALLOW_MOCK_IN_PRODUCTION="true"

# Premium test: bu e-postalarla giriş yapan kullanıcı premium sayılır (geliştirme)
PREMIUM_EMAILS=""

# Site yöneticisi (Clerk ile bu e-posta adresiyle giriş → /admin/feedback sayfası açılır)
# ADMIN_EMAIL="sen@ornek.com"

# Site adresi (Paddle, Stripe, Clerk; canlıda https://alanadin.com)
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Paddle Billing (uluslararası; öncelikli premium ödeme) ---
# https://developer.paddle.com/ — Sandbox ve Live ayrı anahtarlar.
# Fiyat: Paddle Dashboard’da recurring price oluştur → pri_... id
PADDLE_API_KEY="pdl_sdbx_apikey_..." # veya canlı api key
PADDLE_ENVIRONMENT="sandbox" # sandbox | production
PADDLE_PRICE_ID_PREMIUM="pri_..."
PADDLE_WEBHOOK_SECRET="..."
# Paddle.js (Checkout overlay / transactionId yolu için)
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN="test_..." # Developer tools → Client-side token
NEXT_PUBLIC_PADDLE_ENVIRONMENT="sandbox" # sandbox | production

# NEXT_PUBLIC_CONTACT_EMAIL="destek@alanadin.com"

# Resend (isteğe bağlı)
# RESEND_API_KEY=""
# RESEND_FROM="PromptLab <onboarding@resend.dev>"

# Analitik (isteğe bağlı)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN="alanadin.com"
# NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# Stripe
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# STRIPE_PRICE_ID_PREMIUM="price_..."
# Tek seferlik kredi paketleri (Dashboard’da one-time price oluştur)
# STRIPE_PRICE_ID_CREDITS_50="price_..."
# STRIPE_PRICE_ID_CREDITS_100="price_..."

# Paddle kredi paketleri (tek seferlik ürün fiyat id’leri, pri_...)
# PADDLE_PRICE_ID_CREDITS_50="pri_..."
# PADDLE_PRICE_ID_CREDITS_100="pri_..."
